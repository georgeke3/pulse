<svg width="512" height="512" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background: Deep, focused black -->
  <rect width="512" height="512" rx="128" fill="#0F172A"/>
  
  <!-- The "Kettlebell-Brain" Concept -->
  <!-- Kettlebell Handle: Representing the 'Weight' of mental training -->
  <path d="M156 180C156 124.772 200.772 80 256 80C311.228 80 356 124.772 356 180V220H156V180Z" stroke="white" stroke-width="40" stroke-linecap="round"/>
  
  <!-- Kettlebell Body / Brain Lobes: High-intensity Pulse/Purple -->
  <path d="M120 220C120 220 100 240 100 300C100 380 170 440 256 440C342 440 412 380 412 300C412 240 392 220 392 220H120Z" fill="#9333EA"/>
  
  <!-- Pulse Line: Representing the 'Readiness' / CNS signal -->
  <path d="M160 320L210 320L235 260L275 380L300 320L350 320" stroke="white" stroke-width="24" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
